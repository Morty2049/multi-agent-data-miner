# Copy to `.env` (gitignored) and tweak if needed.
# Real environment variables override .env values.

# Hard daily cap on how many vacancies /api/parse will accept.
# Prevents a runaway autopilot from spamming the vault.
JOB_MINER_DAILY_CAP=600

# Optional — override where the API server reads/writes its vault and
# data dir. Defaults to `obsidian_vault/` and `data/` next to config.py.
# Useful when the server runs from a worktree or container but you want
# the vault to stay in one canonical place.
# JOB_MINER_VAULT_DIR=/absolute/path/to/obsidian_vault
# JOB_MINER_DATA_DIR=/absolute/path/to/data

# Optional — Google API key used by the offline legacy skills miner
# (legacy/skills_miner_adk.py). Not used by the Chrome plugin itself.
GOOGLE_API_KEY=
