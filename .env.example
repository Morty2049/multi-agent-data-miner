# Copy to `.env` (gitignored) and tweak if needed.
# Real environment variables override .env values.

# Hard daily cap on how many vacancies /api/parse will accept.
# Prevents a runaway autopilot from spamming the vault.
JOB_MINER_DAILY_CAP=600

# Optional — Google API key used by the offline skills miner
# (skills_miner_adk.py). Not used by the Chrome plugin itself.
GOOGLE_API_KEY=
