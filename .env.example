# Copy to `.env` (gitignored) and fill in.
# Everything here can also be set via real environment variables — process env wins.

# ── LinkedIn account ──────────────────────────────────────────────
# Which persistent Playwright profile dir to use. ONLY use the "market"
# account — never the personal one. Default: linkedin_session_market
LINKEDIN_SESSION_DIR=linkedin_session_market

# Account email used for the login flow (informational print only).
LINKEDIN_ACCOUNT_EMAIL=palexe888@gmail.com

# Path to a real Chrome binary (macOS default shown).
CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# ── Anti-ban pacing ───────────────────────────────────────────────
# Random delay between pages while collecting lists.
LINKEDIN_COLLECT_DELAY_MIN=3
LINKEDIN_COLLECT_DELAY_MAX=8

# Random delay between individual job parses in run_queue.py.
LINKEDIN_PARSE_DELAY_MIN=8
LINKEDIN_PARSE_DELAY_MAX=20

# Hard daily cap on successfully parsed vacancies.
LINKEDIN_DAILY_PARSE_CAP=600

# Exponential backoff on transient errors.
LINKEDIN_BACKOFF_BASE=30
LINKEDIN_BACKOFF_MAX=600
LINKEDIN_BACKOFF_MAX_ATTEMPTS=5

# ── Other ─────────────────────────────────────────────────────────
GOOGLE_API_KEY=
